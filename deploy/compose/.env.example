# ==============================================================================
# OWS Self-Hosted Verifier Deployment Environment Settings
# Copy this file to .env and configure for your local pilot environment.
# DO NOT commit real passwords/secrets to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL Database Settings
# ------------------------------------------------------------------------------
POSTGRES_DB=ows_verifier
POSTGRES_USER=ows
# IMPORTANT: Replace with a strong, secure password in production!
POSTGRES_PASSWORD=replace-with-a-secure-db-password
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Verifier Server Settings
# ------------------------------------------------------------------------------
# Set to 'Production' to enforce strict security checks on startup.
# In 'Production' mode, the server will immediately abort if insecure keys
# or local JSON storage are used.
VerifierEnvironment=Production

# ------------------------------------------------------------------------------
# Verifier Storage Configuration
# ------------------------------------------------------------------------------
VerifierStorage__Provider=postgres
VerifierStorage__PostgresConnectionString=Host=postgres;Port=5432;Database=ows_verifier;Username=ows;Password=replace-with-a-secure-db-password

# Package Submission File Storage Location
# Matches the absolute path in the container where packages are persisted.
# Make sure this matches the volume mapping mount point in docker-compose.yml.
VerifierStorage__LocalStoragePath=/app/packages

# ------------------------------------------------------------------------------
# Verifier API Security Settings
# ------------------------------------------------------------------------------
# API Key Guard secret (Must be at least 16 characters in Production mode)
# Required for verifying client package verification requests.
VerifierSecurity__ApiKey=replace-with-a-secure-16-char-api-key

# Client CLI API Key for status/smoke test scripts (must match VerifierSecurity__ApiKey)
OWS_VERIFIER_API_KEY=replace-with-a-secure-16-char-api-key

# Verifier Receipt Signing Key (Must be at least 16 characters in Production mode)
# Secret key used by the verifier to sign the verification receipts.
VerifierSecurity__SigningKey=replace-with-a-secure-16-char-signing-key

# ------------------------------------------------------------------------------
# Host Networking Settings
# ------------------------------------------------------------------------------
# Port mapped externally on the host system to listen for verifier requests.
VERIFIER_PORT=5078

# Optional custom image tag if not using ows-verifier:latest
# OWS_VERIFIER_IMAGE=ows-verifier:latest
